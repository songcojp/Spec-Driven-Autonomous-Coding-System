{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: ide:build",
      "type": "npm",
      "script": "ide:build",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "npm: ide:watch",
      "type": "npm",
      "script": "ide:watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation in watch mode",
          "endsPattern": "Found [0-9]+ errors?\\. Watching for file changes\\."
        }
      }
    }
  ]
}
