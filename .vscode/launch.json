{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SpecDrive IDE Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--user-data-dir=${workspaceFolder}/.autobuild/vscode-extension-host-user-data",
        "--extensions-dir=${workspaceFolder}/.autobuild/vscode-extension-host-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "specdrive: f5 setup"
    }
  ]
}
